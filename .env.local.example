# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.
# Full reference: docs/env-vars.md

# --- Frontend-safe (NEXT_PUBLIC_ only) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-side ONLY (never exposed to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=

# Other server-side secrets live in Supabase Vault / Vercel env (see docs/env-vars.md):
# ANTHROPIC_API_KEY, OPENAI_API_KEY, DETECTZESTACK_API_KEY,
# DATAFORSEO_LOGIN, DATAFORSEO_PASSWORD, CRON_SECRET, INTERNAL_ADMIN_SECRET, ...
